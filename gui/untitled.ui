   <property name="styleSheet">
    <string notr="true">QPushButton#previous_button,
QPushButton#next_button,
QPushButton#shuffle_button,
QPushButton#repeat_button {
    background-color: transparent;
    border: none;
    border-radius: 30px;
    min-width: 60px;
    max-width: 60px;
    min-height: 60px;
    max-height: 60px;
    qproperty-iconSize: 32px 32px;
    padding: 0px;
}


QPushButton#previous_button:hover,
QPushButton#next_button:hover,
QPushButton#shuffle_button:hover,
QPushButton#repeat_button:hover {
    background-color: rgba(255, 255, 255, 20);
}

QPushButton#previous_button:pressed,
QPushButton#next_button:pressed,
QPushButton#shuffle_button:pressed,
QPushButton#repeat_button:pressed {
    background-color: rgba(255, 255, 255, 35);
}


QPushButton#shuffle_button:checked,
QPushButton#repeat_button:checked {
    background-color: rgba(255, 255, 255, 45);
}
</string>
