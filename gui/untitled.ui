    padding: 0px;
}

QPushButton#pp_button:hover {
    background-color: rgb(245, 245, 245);
}

QPushButton#pp_button:pressed {
    background-color: rgb(230, 230, 230);
}

QPushButton#pp_button:checked {
    background-color: rgb(235, 235, 235);
}

QPushButton#pp_button:checked:hover {
    background-color: rgb(225, 225, 225);
}

QPushButton#pp_button:disabled {
    background-color: rgb(210, 210, 210);
}</string>
